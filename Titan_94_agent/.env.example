# ── Gemini AI ────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Telegram Bot ─────────────────────────────────────────
# Create bot via @BotFather → get token
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_ADMIN_CHAT_ID=
# Optional: channel ID to broadcast reports (e.g., -100xxxxxxx)
TELEGRAM_REPORT_CHANNEL=

# ── TON Blockchain ────────────────────────────────────────
# Network: mainnet | testnet
TON_NETWORK=mainnet
# TonCenter API key (get from https://toncenter.com/api/v2)
TON_API_KEY=
# TONAPI key (get from https://toncenter.com or https://tonapi.io)
TONAPI_KEY=
# 24-word wallet mnemonic (optional, read-only without it)
TON_MNEMONIC=
# Your deployed GenesisTitan contract address
TITAN_CONTRACT_ADDRESS=

# ── Agent Settings ────────────────────────────────────────
# Scan interval in ms (default: 300000 = 5 minutes)
SCAN_INTERVAL_MS=300000
# Report interval in ms (default: 3600000 = 1 hour)
REPORT_INTERVAL_MS=3600000
# Max contracts to scan per round
MAX_CONTRACTS=10
# Bug bounty scanning mode (true/false)
BUG_BOUNTY_MODE=true
