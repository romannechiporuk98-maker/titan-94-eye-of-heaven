    "@ton/ton": "^16.2.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@tact-lang/compiler": ">=1.6.13 <2.0.0",
    "@ton/blueprint": ">=0.40.0",
    "@ton/sandbox": ">=0.37.0",
    "@ton/test-utils": ">=0.11.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
