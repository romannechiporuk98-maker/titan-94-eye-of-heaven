{
  "name": "titan-94-agent",
  "version": "1.0.0",
  "description": "Autonomous TON AI Agent — Gemini-powered bug bounty hunter and ecosystem monitor",
  "main": "agent.js",
  "scripts": {
    "start": "node agent.js",
